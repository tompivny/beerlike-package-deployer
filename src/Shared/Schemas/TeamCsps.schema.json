{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team Column Security Profiles Assignment",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "team": {
        "type": "string",
        "description": "The team identifier, which can be a \"name\" or a \"teamid\"."
      },
      "removeUnassigned": {
        "type": "boolean",
        "default": false,
        "description": "Whether to remove unassigned column security profiles."
      },
      "columnSecurityProfiles": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{8}-([0-9a-fA-F]{4}-){3}[0-9a-fA-F]{12}$",
          "description": "ID of the Dataverse column security profile."
        }
      }
    },
    "required": [
      "team",
      "columnSecurityProfiles"
    ],
    "additionalProperties": false
  }
}
